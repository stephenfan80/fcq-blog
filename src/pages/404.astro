---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404">
  <div class="not-found">
    <h1>404</h1>
    <p>页面不存在</p>
    <a href="/">返回首页</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 4rem 0;
  }

  .not-found h1 {
    font-family: var(--font-mono);
    font-size: 3rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.3em;
  }

  .not-found p {
    color: var(--color-text-secondary);
    margin-bottom: 2em;
  }
</style>
